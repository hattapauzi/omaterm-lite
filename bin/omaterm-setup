echo
echo "Welcome to Omaterm Lite! Let's get you set up."
echo

prompt_confirm() {
  local prompt="$1"
  local default="${2:-y}"
  local suffix reply

  if [ "$default" = "y" ]; then
    suffix="[Y/n]"
  else
    suffix="[y/N]"
  fi

  while true; do
    printf "%s %s " "$prompt" "$suffix"
    IFS= read -r reply || return 1
    reply="${reply,,}"

    case "$reply" in
      "") [ "$default" = "y" ] && return 0 || return 1 ;;
      y|yes) return 0 ;;
      n|no) return 1 ;;
      *) echo "Please answer yes or no." ;;
    esac
  done
}

# Git identity
if ! git config --global user.name &>/dev/null || ! git config --global user.email &>/dev/null; then
  if prompt_confirm "Identify for Git?" "y"; then
    if command -v gum &>/dev/null; then
      git config --global user.name "$(gum input --placeholder 'Name' --header 'Git name')"
      git config --global user.email "$(gum input --placeholder 'Email' --header 'Git email')"
    else
      local git_name git_email
      printf "Git name: "
      read -r git_name
      printf "Git email: "
      read -r git_email
      git config --global user.name "$git_name"
      git config --global user.email "$git_email"
    fi
  fi
fi

echo
echo "‚úď Setup complete!"
touch "$MARKER"
exec zsh -l "$@"
