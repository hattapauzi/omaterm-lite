#!/bin/bash
set -euo pipefail

# Set the Neovim colorscheme (takes effect on next nvim launch)

THEMES=(
  default
  aether
  bamboo
  catppuccin
  ethereal
  everforest
  flexoki
  gruvbox
  hackerman
  kanagawa
  matteblack
  miasma
  monokai-pro
  nord
  rose-pine
  tokyonight
)

THEME_FILE="$HOME/.config/omaterm/nvim.theme"
CURRENT=$(cat "$THEME_FILE" 2>/dev/null || echo "default")

theme=""
PS3="Neovim theme (current: $CURRENT): "
select selected_theme in "${THEMES[@]}"; do
  if [[ -n "${selected_theme:-}" ]]; then
    theme="$selected_theme"
    break
  fi
  echo "Please choose a valid theme number."
done

mkdir -p "$(dirname "$THEME_FILE")"
echo "$theme" >"$THEME_FILE"
echo "Neovim theme set to $theme (restart nvim to apply)"
