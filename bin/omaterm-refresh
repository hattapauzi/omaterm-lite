#!/bin/bash
set -euo pipefail

# Reinstalls Omaterm Lite with missing packages and default configs.

printf "Refresh Omaterm Lite (including overwriting configs)? [y/N] "
IFS= read -r reply
case "${reply,,}" in
  y|yes) curl -fsSL https://raw.githubusercontent.com/hattapauzi/omaterm-lite/master/install.sh | bash ;;
esac
